        <mxCell id="allk4cJPCkBnzGQoUKhb-24" parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;RNF&lt;/th&gt;&lt;th&gt;Descrição&lt;/th&gt;&lt;th&gt;Justificativa&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;RNF1&lt;/td&gt;&lt;td&gt;Performance&lt;/td&gt;&lt;td&gt;O site deve carregar o menu em até 2 segundos, mesmo com grande volume de pedidos.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;RNF2&lt;/td&gt;&lt;td&gt;Segurança&lt;/td&gt;&lt;td&gt;Dados dos clientes e pagamentos devem ser criptografados (HTTPS, PCI compliance).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;RNF3&lt;/td&gt;&lt;td&gt;Disponibilidade&lt;/td&gt;&lt;td&gt;Sistema deve estar disponível 99% do tempo, com manutenção programada mínima.&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
