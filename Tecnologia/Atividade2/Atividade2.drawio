      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="allk4cJPCkBnzGQoUKhb-15" parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Prioridade&lt;/th&gt;&lt;th&gt;Requisito Funcional (RF)&lt;/th&gt;&lt;th&gt;Descrição&lt;/th&gt;&lt;th&gt;Complexidade&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;&amp;nbsp;RF1: Cadastro de clientes&lt;/td&gt;&lt;td&gt;Permitir que clientes criem e editem seu perfil com nome, endereço, telefone e e-mail.&lt;/td&gt;&lt;td&gt;Média&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;RF2: Menu online&lt;/td&gt;&lt;td&gt;Exibir o cardápio completo com pizzas, bebidas e acompanhamentos, incluindo preços e descrição.&lt;/td&gt;&lt;td&gt;Baixa&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;3&lt;/td&gt;&lt;td&gt;RF3: Pedido online&lt;/td&gt;&lt;td&gt;Permitir que clientes adicionem itens ao carrinho, selecionem quantidade e façam o pedido.&lt;/td&gt;&lt;td&gt;Alta&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;4&lt;/td&gt;&lt;td&gt;RF4: Pagamento online&lt;/td&gt;&lt;td&gt;Integrar meios de pagamento (cartão, PIX, PayPal) para finalizar pedidos.&lt;/td&gt;&lt;td&gt;Alta&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&amp;nbsp;5&amp;nbsp;&lt;/td&gt;&lt;td&gt;RF5: Rastreamento do pedido&lt;/td&gt;&lt;td&gt;Mostrar status do pedido em tempo real (preparação, entrega a caminho, entregue).&lt;/td&gt;&lt;td&gt;Média&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
